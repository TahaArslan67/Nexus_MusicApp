# Nexus Environment Configuration
# Kopyala: cp .env.example .env
# NOT: .env dosyasını ASLA git'e ekleme!

# Security
NEXUS_SECRET_KEY=change-me-to-a-random-32-char-string
NEXUS_DATABASE_URL=sqlite+aiosqlite:///./nexus.db

# YouTube / Download
NEXUS_CACHE_DIR=./cache/ytdlp
NEXUS_PROXY_LIST=http://proxy1:8080,http://proxy2:8080,socks5://proxy3:1080

# Redis (optional — disabled by default)
NEXUS_REDIS_URL=redis://localhost:6379/0
NEXUS_USE_REDIS=false

# Logging
NEXUS_LOG_LEVEL=INFO
NEXUS_LOG_FILE=./logs/nexus.log